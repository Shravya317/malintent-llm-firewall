{
  "manifest_version": 3,
  "name": "MalIntent Firewall",
  "version": "1.0",
  "description": "Premium protection against malicious prompts and PII leaks.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://groq.com/*",
    "*://*.groq.com/*",
    "*://*.antigravity.dev/*",
    "*://malintent-firewall.vercel.app/*",
    "*://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://groq.com/*",
        "*://*.groq.com/*",
        "*://*.antigravity.dev/*"
      ],
      "css": ["content.css"],
      "js": ["content_script.js"]
    },
    {
      "matches": [
        "*://malintent-firewall.vercel.app/*",
        "*://localhost/*"
      ],
      "js": ["token_bridge.js"]
    }
  ],
  "action": {
    "default_title": "MalIntent Firewall",
    "default_popup": "popup.html"
  }
}
