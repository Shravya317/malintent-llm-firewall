# =============================================================================
# # Cloud Run deployment:
# Configure these same environment variables in the Google Cloud Run service.
# backend/.env.example
# =============================================================================
# Copy this file to backend/.env and fill in all values.
# NEVER commit backend/.env to Git.
#
# Generation commands
# -------------------
#
# PG_CRYPTO_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Default database connection.
# During local Docker development, use localhost.
# During production deployment (Cloud Run), use the Supabase Transaction Pooler.

DATABASE_URL=postgresql://malintent:your_local_postgres_password@localhost:5432/malintent

# Password for the local postgres:16 Docker container.
POSTGRES_PASSWORD=your_local_postgres_password


# -----------------------------------------------------------------------------
# Supabase Production Database
# -----------------------------------------------------------------------------
# Password chosen while creating the Supabase project.
# Used inside the connection strings below.

SUPABASE_DB_PASSWORD=your_supabase_database_password

# Direct Connection (Port 5432)

SUPABASE_DIRECT_URL=your_supabase_direct_connection_url

# Transaction Pooler (Port 6543)

SUPABASE_TRANSACTION_POOLER_URL=your_supabase_transaction_pooler_url


# -----------------------------------------------------------------------------
# Encryption Keys
# -----------------------------------------------------------------------------
# Week 4 - Application layer encryption

# Week 7 - PostgreSQL pgcrypto field-level encryption

PG_CRYPTO_KEY=your_generated_pg_crypto_key

# -----------------------------------------------------------------------------
# Hugging Face
# -----------------------------------------------------------------------------
# Required only while downloading PromptGuard-86M during Docker build.

HUGGINGFACE_TOKEN=your_huggingface_token


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of frontend origins allowed to access the API.

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# -----------------------------------------------------------------------------
# Groq (Comparison Mode raw LLM proxy)
# -----------------------------------------------------------------------------
# Used by routers/llm.py to proxy prompts to Groq for the unprotected
# Comparison Mode panel.
# Get your key from: https://console.groq.com/keys

GROQ_API_KEY=your_groq_api_key


# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
# Set to "true" to print SQLAlchemy queries.
# Never enable in production.

SQLALCHEMY_ECHO=false

# ── AUTHENTICATION ────────────────────────────────────────────────────────────
# Used to sign and verify JWT tokens for the landing page login.
# Generate a secure secret using: python -c "import secrets; print(secrets.token_hex(32))"

SUPABASE_JWT_SECRET=your_secure_jwt_secret_here

# SMTP Configuration for Email OTP

SMTP_EMAIL=your_email@gmail.com

SMTP_PASSWORD=your_16_char_app_password
